# Node
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Local secrets / config (never commit)
.env
.env.local
*.local.json
config.local.yaml
secrets.yaml

# Build outputs / temp
dist/
build/
*.log
tmp/
*_tmp.js
*_tmp.py

# Skill ad-hoc debugging scratch (per-session captures, not curated reference data).
# Anything we want preserved should be moved into stample/<site>/sample/ instead.
skill/**/event_json/
skill/**/responce_result/
skill/**/_scratch/
skill/**/_debug/

# Per-run debug dumps under any stample/<site>/sample/ — kept local for diagnosis,
# not for redistribution. Real ground-truth lives in numbered batches (sample/1/ etc.).
stample/**/sample/_our_ev/
stample/**/sample/_diff_report/
stample/**/sample/_smoke_10x/
stample/**/chrome_profile/

# Screenshots: kept locally for personal reference, not redistributed.
stample/screenshots/

# Python bytecode (anywhere)
**/__pycache__/
*.pyc
*.pyo

# Large data files (use Git LFS if needed)
*.jsonl
data/*.json
sample/**/dump.json

# Bright Data / proxy credentials (don't commit creds even if obfuscated)
proxy_creds.txt
brd_*.txt

# Local PX SDK captures (PerimeterX copyright + license restrictions on redistribution).
# The committed copies under stample/{ifood,grub}/source/ are the canonical research
# snapshots; any local re-captures should stay local.
_live_*.js
_live_*_init.js
